{
  "name": "mac-closed-awake",
  "version": "1.0.0",
  "description": "Your Mac stays awake — lid closed or not. No sleep, ever.",
  "main": "main.js",
  "author": "Harry Huang <onezion12344@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onezion12344/mac-closed-awake"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:mas": "electron-builder --mac --mas",
    "dist": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.onezion.mac-closed-awake",
    "productName": "MacClosedAwake",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "icon": "icon.icns",
      "entitlements": "entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "mas": {
      "category": "public.app-category.utilities",
      "entitlements": "entitlements.mas.plist"
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
